<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Центрируем ВСЁ содержимое -->
    <LinearLayout
        android:id="@+id/content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="20dp"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Заголовок -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:layout_marginBottom="14dp" />

        <!-- Карточка с инфой -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_details_card"
            android:padding="18dp"
            android:orientation="vertical"
            android:layout_marginBottom="22dp">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="@color/textPrimary"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="@color/textPrimary"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvOrganizer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="@color/textPrimary"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvTemplate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Template: —"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvGuests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="@color/textPrimary"/>
        </LinearLayout>

        <!-- Ряд круглых кнопок -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="18dp">

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_circle_primary"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/white"
                android:contentDescription="Edit"/>


            <ImageButton
                android:id="@+id/btnInvite"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_circle_primary"
                android:src="@android:drawable/ic_dialog_email"
                app:tint="@color/white"
                android:contentDescription="Invite"/>

            <ImageButton
                android:id="@+id/btnGuests"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_circle_primary"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/white"
                android:contentDescription="Guests"/>

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:background="@drawable/bg_circle_danger"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/white"
                android:contentDescription="Delete"/>


        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
