<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- : height=match_parent чтобы центрирование работало -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Это центрируется по экрану -->
            <LinearLayout
                android:id="@+id/content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <!-- Header -->
                <TextView
                    android:id="@+id/tvHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Редактирование"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="16dp"/>

                <!-- Form card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_form_card"
                    android:padding="18dp">

                    <!-- Имя -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Имя"
                        android:textColor="@color/textHint"
                        android:textSize="14sp"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input"
                        android:hint="Например: John"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textHint"
                        android:inputType="textPersonName"
                        android:layout_marginBottom="14dp"/>

                    <!-- Контакты -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Контакты"
                        android:textColor="@color/textHint"
                        android:textSize="14sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Группа"
                        android:textColor="@color/textHint"
                        android:textSize="14sp"
                        android:layout_marginBottom="6dp"/>

                    <AutoCompleteTextView
                        android:id="@+id/etGroup"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input"
                        android:hint="Например: Друзья / Работа"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textHint"
                        android:inputType="text"
                        android:layout_marginBottom="14dp"/>

                    <EditText
                        android:id="@+id/etContacts"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input"
                        android:hint="Email / телефон"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textHint"
                        android:inputType="text"
                        android:layout_marginBottom="14dp"/>

                    <!-- Фото -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Фото"
                        android:textColor="@color/textHint"
                        android:textSize="14sp"
                        android:layout_marginBottom="6dp"/>

                    <EditText
                        android:id="@+id/etPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input"
                        android:hint="Photo URL"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textHint"
                        android:inputType="textUri"
                        android:layout_marginBottom="18dp"/>

                    <!-- Save -->
                    <Button
                        android:id="@+id/btnSavePerson"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_btn_primary"
                        android:text="Сохранить"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/primary"
                        android:textSize="18sp"
                        android:textColor="@color/textPrimary"/>
                </LinearLayout>

            </LinearLayout>

        </FrameLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
