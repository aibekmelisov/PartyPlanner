<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/bg">

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Заголовок -->
            <TextView
                android:id="@+id/tvScreenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Редактирование"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/textPrimary"
                android:layout_marginBottom="14dp"/>

            <!-- CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_details_card"
                android:padding="18dp"
                android:orientation="vertical">

                <!-- Название -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Название"
                    android:textColor="@color/textHint"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:hint="Например: Art Workshop"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textHint"
                    android:layout_marginBottom="14dp"/>

                <!-- Адрес -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Адрес"
                    android:textColor="@color/textHint"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etAddress"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:hint="Например: Rome Art Studio"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textHint"
                    android:layout_marginBottom="14dp"/>

                <!-- Poster URL -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Poster URL (можно пусто)"
                    android:textColor="@color/textHint"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etPosterUrl"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:hint="https://..."
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textHint"
                    android:layout_marginBottom="14dp"/>

                <!-- Organizer -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Организатор"
                    android:textColor="@color/textHint"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <Spinner
                    android:id="@+id/spOrganizer"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColorHint="@color/textHint"
                    android:layout_marginBottom="16dp"/>

                <!-- Guests -->
                <Button
                    android:id="@+id/btnGuests"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Выбрать гостей"
                    android:textAllCaps="false"
                    android:textSize="18sp"
                    app:backgroundTint="@color/primary"
                    android:textColor="@color/textPrimary"
                    android:background="@drawable/bg_btn_pill"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tvGuests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Гости: —"
                    android:textSize="16sp"
                    android:textColor="@color/textHint"
                    android:layout_marginBottom="16dp"/>

                <!-- DateTime -->
                <Button
                    android:id="@+id/btnPickDateTime"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Выбрать дату и время"
                    android:textAllCaps="false"
                    android:textSize="18sp"
                    app:backgroundTint="@color/primary"

                    android:textColor="@color/textPrimary"
                    android:background="@drawable/bg_btn_pill"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tvChosenDateTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="16sp"
                    android:textColor="@color/textHint"
                    android:layout_marginBottom="18dp"/>

                <!-- INVITATION -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Приглашение"
                    android:textColor="@color/textHint"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <!-- Template -->
                <Spinner
                    android:id="@+id/spInviteTemplate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColorHint="@color/textHint"
                    android:layout_marginBottom="12dp"/>

                <!-- Custom message -->
                <EditText
                    android:id="@+id/etInviteMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="90dp"
                    android:background="@drawable/bg_input"
                    android:padding="14dp"
                    android:hint="Текст приглашения (необязательно)"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/textHint"
                    android:layout_marginBottom="12dp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/swInviteMap"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Добавить ссылку на карту"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="18dp"/>

                <!-- REMINDER -->
                <!-- REMINDER -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Напоминание"
                    android:textColor="@color/textHint"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/swReminder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Включить напоминание"
                    android:textColor="@color/textPrimary"
                    android:layout_marginBottom="10dp"/>

                <Spinner
                    android:id="@+id/spReminderType"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColorHint="@color/textHint"
                    android:layout_marginBottom="10dp"/>

                <Button
                    android:id="@+id/btnPickReminderTime"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Выбрать дату напоминания"
                    android:textAllCaps="false"

                    app:backgroundTint="@color/primary"

                    android:visibility="gone"
                    android:background="@drawable/bg_btn_pill"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/tvReminderChosen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/textHint"
                    android:visibility="gone"
                    android:layout_marginBottom="18dp"/>                <!-- Save -->
                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Сохранить"
                    android:textAllCaps="false"
                    android:textSize="18sp"
                    android:textColor="@color/textPrimary"
                    app:backgroundTint="@color/primary"

                    android:background="@drawable/bg_btn_primary"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
